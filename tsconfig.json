{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@lib/*": ["lib/*"],
      "@components/*": ["components/*"],
      "@hooks/*": ["src/hooks/*"],
      "@assets/*": ["assets/*"],
      "@theme": ["src/lib/theme"],
      "@store/*": ["src/store/*"],
      "@engine/*": ["src/engine/*"]
    }
  }
}
